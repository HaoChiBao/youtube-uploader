# Path to channels.yaml (default: config/channels.yaml)
UPLOADER_CONFIG=config/channels.yaml

# Override Google OAuth client secret path (optional; also set in channels.yaml)
# GOOGLE_CLIENT_SECRET_PATH=secrets/shared/client_secret.json

# S3 settings (only needed when using s3:// URIs)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# HTTP API key (Phase 2 — not used yet)
# UPLOADER_API_KEY=
