# Path to channels.yaml
UPLOADER_CONFIG=config/channels.yaml

# ── Google OAuth (preferred: set these instead of a JSON file) ──────────────
# Create a Web application OAuth client in Google Cloud Console.
# Register redirect URIs (no trailing slash):
#   CLI:  http://localhost:8765  and  http://127.0.0.1:8765
#   API:  http://127.0.0.1:8000/v1/oauth/callback  (when using uploader-api / FastAPI UI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_OAUTH_PORT=8765
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8765
GOOGLE_OAUTH_JAVASCRIPT_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# Optional file fallback instead of GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# GOOGLE_CLIENT_SECRET_PATH=secrets/shared/client_secret.json

# ── Cloudflare R2 (S3-compatible object storage) ────────────────────────────
# When set, all durable state lives in R2 (local config/ and secrets/ are mirrored).
#
# Bucket layout:
#   config/channels.yaml
#   secrets/{channel_id}/youtube_token.json
#   state/{channel_id}/channel.meta.json
#   state/{channel_id}/upload_registry.txt
#   queue/{channel_id}/{job_id}/video.mp4
#   queue/{channel_id}/{job_id}/thumbnail.png
#   queue/{channel_id}/{job_id}/description.txt
#   queue/{channel_id}/{job_id}/metadata.json
#   queue/{channel_id}/{job_id}/privacy.txt
#   queue/{channel_id}/{job_id}/is_short.txt
#   uploaded/{channel_id}/{job_id}/       (moved here after YouTube upload)
#   logs/{channel_id}/run-YYYYMMDD.log      (optional, cron logs)
#
CLOUDFLARE_R2_BUCKET=my-uploader-bucket
CLOUDFLARE_R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ── Cron / worker defaults ──────────────────────────────────────────────────
UPLOADER_DEFAULT_CHANNEL=justcavefire
UPLOADER_UPLOAD_RETRIES=5
UPLOADER_LOG_DIR=logs

# ── Default queued video metadata (when flags omitted on queue add) ─────────
# Override per-channel in channels.yaml (defaults: / upload_defaults:)
UPLOADER_DEFAULT_PRIVACY=private
UPLOADER_DEFAULT_IS_SHORT=false
UPLOADER_DEFAULT_CATEGORY_ID=10
UPLOADER_DEFAULT_MADE_FOR_KIDS=false
UPLOADER_DEFAULT_LANGUAGE=en
# UPLOADER_DEFAULT_TAGS=          # leave unset for no tags; or e.g. video,youtube

# Legacy S3 vars (deprecated — use CLOUDFLARE_R2_* above)
# UPLOADER_STORAGE_BUCKET=
# S3_ENDPOINT_URL=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Local FastAPI server (uploader-api) ─────────────────────────────────────
# UPLOADER_API_PUBLIC_URL=http://127.0.0.1:8000
# UPLOADER_API_HOST=127.0.0.1
# UPLOADER_API_PORT=8000
# UPLOADER_API_RELOAD=1
# UPLOADER_DASHBOARD_CACHE_TTL=60
# UPLOADER_CONFIG_CACHE_TTL=120
# UPLOADER_TOKEN_CACHE_TTL=300
# UPLOADER_API_KEY=                  # require X-API-Key header on job ingest routes
