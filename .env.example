# Path to channels.yaml
UPLOADER_CONFIG=config/channels.yaml

# ── Google OAuth (preferred: set these instead of a JSON file) ──────────────
# Create a Web application OAuth client in Google Cloud Console.
# Register redirect URIs (no trailing slash):
#   http://localhost:8080
#   http://127.0.0.1:8080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_OAUTH_PORT=8765
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8765
GOOGLE_OAUTH_JAVASCRIPT_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# Optional file fallback instead of GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# GOOGLE_CLIENT_SECRET_PATH=secrets/shared/client_secret.json

# ── Cron / worker defaults ──────────────────────────────────────────────────
UPLOADER_DEFAULT_CHANNEL=channel-a
UPLOADER_UPLOAD_RETRIES=5
UPLOADER_LOG_DIR=logs

# ── S3 (only needed when using s3:// URIs) ───────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── HTTP API key (Phase 3 — not used yet) ───────────────────────────────────
# UPLOADER_API_KEY=
