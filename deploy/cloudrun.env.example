# Copy values into Cloud Run env vars (Console → Edit & deploy → Variables)
# or use: gcloud run services update uploader-api --set-env-vars-file=deploy/cloudrun.env
#
# Required: R2 must be configured — the container has no persistent disk.
# Run `uploader storage init` locally once before first deploy (or POST /v1/storage/init after deploy).

UPLOADER_API_PUBLIC_URL=https://uploader-api-XXXXXXXX-uc.a.run.app
UPLOADER_API_HOST=0.0.0.0
UPLOADER_STATIC_DIR=/app/api/static

# Auth (required for public Cloud Run URL)
UPLOADER_API_KEY=
UPLOADER_DASHBOARD_PASSWORD=
UPLOADER_SESSION_SECURE=1
UPLOADER_SESSION_DAYS=7

# Google OAuth — Web application client; add redirect URI:
#   https://YOUR-SERVICE-URL/v1/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# Cloudflare R2
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ai-music-assembler cross-bucket read (optional — same token can read both buckets)
# ASSEMBLY_R2_BUCKET=music-assembly-data
# ASSEMBLY_R2_ENDPOINT_URL=
# ASSEMBLY_R2_REGION=auto
# ASSEMBLY_R2_ACCESS_KEY_ID=
# ASSEMBLY_R2_SECRET_ACCESS_KEY=

# Parallel upload workers (Cloud Run Job)
# UPLOADER_WORKER_BACKEND=cloudrun
# UPLOADER_UPLOAD_JOB_NAME=youtube-uploader-upload
# UPLOADER_CLOUD_RUN_REGION=northamerica-northeast2
# GOOGLE_CLOUD_PROJECT=
# UPLOADER_MAX_PARALLEL_UPLOADS=5

# One-shot Cloud Scheduler for per-job upload_at (see deploy/cloud-scheduler-upload-at.md)
# Production (youtuber-uploader-app) has this enabled:
UPLOADER_UPLOAD_AT_SCHEDULER=1
UPLOADER_CLOUD_SCHEDULER_LOCATION=us-central1
# UPLOADER_SCHEDULER_OIDC_SA=reconcile-cron@PROJECT.iam.gserviceaccount.com
