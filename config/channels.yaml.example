# Channels are added via: uploader channel add
# Each entry is created automatically from the YouTube channel name / @handle.
#
# When CLOUDFLARE_R2_BUCKET is set in .env, paths resolve to s3:// URIs automatically.
# Run `uploader storage init` once to create the bucket layout and migrate local data.

# Global defaults for queued video jobs (overridden by .env UPLOADER_DEFAULT_*)
defaults:
  privacy: private
  is_short: false
  category_id: "10"
  made_for_kids: false
  language: en
  tags: []   # empty = no YouTube tags (recommended default for any channel)

# Example entry after channel add (R2):
#   id: justcavefire
#   category: korean          # must exist in categories: list below
#   token_path: s3://your-bucket/secrets/justcavefire/youtube_token.json
#   registry_path: s3://your-bucket/state/justcavefire/upload_registry.txt
#
# Per-channel upload overrides (optional):
#   upload_defaults:
#     privacy: public
#     is_short: true
#     tags: [lofi, chill]
#
# Saved assembly/content categories (dashboard: Categories section):
#   categories:
#     - korean
#     - japanese
#
# Publish scheduling (used by plan / run / queue upload unless --no-schedule):
#   publish:
#     timezone: America/New_York
#     hour: 9              # first video publishes tomorrow at this hour (local)
#     interval_hours: 24   # gap between videos in a batch
#     uploads_per_day: 3   # optional cap on jobs per run (null = no cap)

channels: []

categories: []

google:
  oauth_port: 8765
